### Step 5: Build Server Actions

Follow this secure pattern for ALL server actions:

```typescript
'use server';
import { auth } from '@/app/(auth)/auth';
import { generateImageWithDALLE } from '@/lib/ai/image-generation';

export async function generateImage(input: ImageGenerationInput) {
const session = await auth()                                       ;
if (!session?.user) throw new Error('Unauthorized');

// Generate image using AI service
const imageUrl = await generateImageWithDALLE(input.prompt, input.model) ;

// Save to database
const image = await db.insert(images).values({
...input,
imageUrl,
userId: session.user.id // CRITICAL: Always scope to user
}).returning()                                            ;

return image[0] ;
}

export async function getUserImages() {
const session = await auth()                         ;
if (!session?.user) throw new Error('Unauthorized');

return await db.query.images.findMany({
where: eq(images.userId, session.user.id),
orderBy: desc(images.createdAt)
})                                         ;
}
```

