## 💡 Critical Patterns You Must Follow

### Authentication is Non-Negotiable

Every server action MUST authenticate:

```typescript
'use server';
import { auth } from '@/app/(auth)/auth';

export async function generateImage(input: ImageInput) {
const session = await auth()                             ;
if (!session?.user) throw new Error('Unauthorized');

return await generateImageWithAI({
...input,
userId: session.user.id // CRITICAL: Always scope to user
})                                                        ;
}
```

### Data Isolation is Mandatory

Always scope queries to the current user:

```typescript
// ❌ NEVER do this
const allImages = await db.query.images.findMany() ;

// ✅ ALWAYS do this
const userImages = await db.query.images.findMany({
where: eq(images.userId, user.id)
})                                                  ;
```

### Image Optimization

Always use Next.js Image component:

```tsx
// ✅ Optimized image loading
<Image
src={image.imageUrl}
alt={image.prompt}
width={512}
height={512}
className="rounded-2xl object-cover"
placeholder="blur"
blurDataURL="data:image/jpeg;base64,..."
/>
```

### Handle Generation States

Implement proper loading and error states:

```tsx
'use client';
import { useState } from 'react';

export function ImageGenerator() {
const [isGenerating, setIsGenerating] = useState(false) ;
const [error, setError] = useState(null)                ;

const handleGenerate = async (prompt: string) => {
setIsGenerating(true)                              ;
setError(null)                                     ;

try {
await generateImage({ prompt }) ;
} catch (err) {
setError(err.message)           ;
} finally {
setIsGenerating(false)          ;
}
}                               ;

return (
<div>
{isGenerating && <GenerationProgress />}
{error && <ErrorMessage error={error} />}
<GenerationForm onSubmit={handleGenerate} disabled={isGenerating} />
</div>
)                                                                    ;
}
```

