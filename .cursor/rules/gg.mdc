// Example: Adding image generation tables
export const images = pgTable('images', {
id: serial('id').primaryKey(),
prompt: text('prompt').notNull(),
imageUrl: text('image_url').notNull(),
model: text('model').notNull(), // 'dall-e-3', 'midjourney', etc.
style: text('style'), // 'photorealistic', 'artistic', etc.
